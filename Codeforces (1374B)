#include <bits/stdc++.h>
using namespace std;
using ll = long long;

int main() {
	int t;
	cin >> t;
	while(t--){
	    ll n; cin >> n;
	    if(n == 1){
	         cout << 0 << endl;
	         continue;
	    }
	    
	    ll cnt2 = 0, cnt3 = 0;
	    while(n % 3 == 0){
	        cnt3++;
	        n /= 3;
	    }
	    
	    while(n % 2 == 0){
	        cnt2++;
	        n /= 2;
	    }
	    
	    if(n != 1 || cnt2 > cnt3){
	        cout << -1 << endl;
	    }else{
	        cout << (cnt3 - cnt2) + cnt3 << endl;
	    }
	}
}


